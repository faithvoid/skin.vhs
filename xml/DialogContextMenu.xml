<?xml version="1.0" encoding="UTF-8"?>
<window id="100">
    <defaultcontrol always="true">996</defaultcontrol>

    <controls>
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>720</width>
            <height>480</height>
            <texture colordiffuse="FF000000">colors/white.png</texture>
        </control>
    
        <control type="label">
            <left>40</left>
            <top>30</top>
            <width>300</width>
            <height>40</height>
            <font>font_vhs_large</font>
            <textcolor>vhs_white</textcolor>
            <label>OPTIONS</label>
        </control>
        
        <control type="label">
            <right>40</right>
            <top>30</top>
            <width>300</width>
            <height>40</height>
            <align>right</align>
            <font>font_vhs_large</font>
            <textcolor>vhs_white</textcolor>
            <label>$INFO[System.Time(hh:mm:ss)]</label>
        </control>

        <control type="grouplist" id="996">
            <left>40</left>
            <top>100</top>
            <width>640</width>
            <height>320</height>
            <onleft>996</onleft>
            <onright>996</onright>
            <onup>996</onup>
            <ondown>996</ondown>
            <scrolltime>0</scrolltime>
            <orientation>vertical</orientation>
            <itemgap>0</itemgap>
            
            <control type="button" id="1000">
                <width>640</width>
                <height>38</height>
                <font>font_vhs_medium</font>
                <textoffsetx>40</textoffsetx>
                <textcolor>vhs_white</textcolor>
                <focusedcolor>vhs_green</focusedcolor>
                <texturefocus>-</texturefocus>
                <texturenofocus>-</texturenofocus>
            </control>
        </control>

        <control type="group">
            <left>40</left>
            <top>100</top>
            <width>30</width>
            <height>320</height>
            <control type="label">
                <left>0</left>
                <top>$INFO[Container(996).Row]</top>
                <width>30</width>
                <height>38</height>
                <font>font_vhs_medium</font>
                <textcolor>vhs_green</textcolor>
                <label>►</label>
                <visible>Control.HasFocus(996) | Control.HasFocus(1000)</visible>
            </control>
        </control>
    </controls>
</window>
